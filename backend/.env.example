PORT=3000
NODE_ENV=development

# Local AI. Works only on your laptop, not on Vercel unless you provide a remote Ollama URL.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Optional cloud AI for deployed version. Leave blank if not using it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional Infermedica credentials. Leave blank if you do not have approved access.
INFERMEDICA_APP_ID=
INFERMEDICA_APP_KEY=
INFERMEDICA_DEV_MODE=false

# Local JSON chat logging. Automatically disabled on Vercel.
FILE_LOGGING_ENABLED=true
